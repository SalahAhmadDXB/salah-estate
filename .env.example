# Google Analytics — paste your GA4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (from GSC > Settings > Ownership verification)
NEXT_PUBLIC_GSC_VERIFICATION=

# Resend API key for contact form email notifications
# Get a free key at https://resend.com — add your domain and verify it
RESEND_API_KEY=

# The "from" address for outbound notification emails (must be from a verified Resend domain)
RESEND_FROM=notifications@yourdomain.com
